{
  "profileId": "ServerRelease",
  "displayName": "Dedicated Server Release",
  "description": "Optimized dedicated server build for deployment.",
  "buildProfile": "Release",
  "targets": ["server"],
  "outputDir": "Artifacts/ServerRelease",
  "includeSymbols": false,
  "includeContentRoot": true,
  "cmakeArgs": [
    "-DCMAKE_BUILD_TYPE=Release",
    "-DNOVAFORGE_ASSERTIONS=OFF"
  ],
  "artifacts": [
    "nova_forge_server"
  ],
  "contentDirs": [
    "Content/Data",
    "Content/Definitions",
    "Content/Buildables",
    "Content/Salvage",
    "Content/Worldgen",
    "Content/Factions",
    "Content/Seasons"
  ],
  "releaseGates": [
    "compile_succeeds",
    "validation_succeeds",
    "smoke_tests_succeed",
    "packaging_succeeds"
  ]
}
