{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "novaforge/server_config.schema.json",
  "title": "NovaForge Server Configuration",
  "description": "Schema for NovaForge server_config.json",
  "type": "object",
  "required": ["version", "whitelist_enabled", "max_players", "tick_rate", "log_level"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Server configuration schema version",
      "pattern": "^\\d+\\.\\d+$"
    },
    "whitelist_enabled": {
      "type": "boolean",
      "description": "Whether the server player whitelist is enforced"
    },
    "max_players": {
      "type": "integer",
      "description": "Maximum number of concurrent connected players",
      "minimum": 1,
      "maximum": 10000
    },
    "tick_rate": {
      "type": "integer",
      "description": "Server simulation ticks per second",
      "minimum": 1,
      "maximum": 128
    },
    "log_level": {
      "type": "string",
      "description": "Logging verbosity level",
      "enum": ["trace", "debug", "info", "warn", "error", "critical"]
    }
  }
}
