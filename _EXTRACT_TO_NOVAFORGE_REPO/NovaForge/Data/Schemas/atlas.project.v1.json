{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "atlas.project.v1",
  "title": "Atlas Project",
  "description": "Schema for Atlas Engine project files (.atlas)",
  "type": "object",
  "required": ["schema", "name", "version"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "atlas.project.v1",
      "description": "Schema identifier and version"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable project name"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version (e.g. 1.0.0)"
    },
    "runtime": {
      "type": "object",
      "properties": {
        "tickRate": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120,
          "default": 30
        },
        "maxPlayers": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64,
          "default": 20
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Rendering2D", "Rendering3D", "Physics2D", "Physics3D",
          "UI", "Networking", "Simulation", "Audio", "AI", "Animation"
        ]
      },
      "uniqueItems": true,
      "default": ["Rendering3D", "Physics3D", "UI", "Networking", "AI"]
    }
  },
  "additionalProperties": false
}
